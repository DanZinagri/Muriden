<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<GeneDef>
		<defName>Muriden_Resolve</defName>
		<label>muriden resolve</label>
		<description>Carriers of this gene have improved dodge and work speed.</description>
		<biostatCpx>2</biostatCpx>
		<biostatMet>-2</biostatMet>
		<displayCategory>Miscellaneous</displayCategory>
		<statFactors>
			<MeleeDodgeChance>1.2</MeleeDodgeChance>
			<WorkSpeedGlobal>1.1</WorkSpeedGlobal>
		</statFactors>
		<iconPath>UI/Icons/Genes/Muriden_Icon</iconPath>
		<displayOrderInCategory>103</displayOrderInCategory>
        <modExtensions>
            <li Class="BigAndSmall.PawnExtension">
                <canWalkOnCreep>true</canWalkOnCreep>
                <renderCacheOff>true</renderCacheOff>
                <thingDefSwap>Muriden_Race</thingDefSwap>
            </li>
        </modExtensions>
		<abilities>
			<li>MuridenCourage</li>
		</abilities>
		<exclusionTags>
			<li>ML_Stats</li>
		</exclusionTags>
	</GeneDef>
	
