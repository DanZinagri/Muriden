<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<TraderKindDef>
		<defName>Muriden_Caravan_Medieval_BulkGoodsMerchant</defName>
		<label>bulk goods merchant</label>
		<commonality>3</commonality>
		<stockGenerators>
			<li Class="StockGenerator_SingleDef">
				<thingDef>Silver</thingDef>
				<countRange>750~1200</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>Kibble</thingDef>
				<countRange>150~450</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>WoodLog</thingDef>
				<countRange>100~450</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>Cloth</thingDef>
				<countRange>100~400</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>MedicineHerbal</thingDef>
				<countRange>0~24</countRange>
			</li>
			<li Class="StockGenerator_Animals">
				<maxWildness>0.70</maxWildness>
				<tradeTagsSell>
					<li>AnimalFarm</li>
				</tradeTagsSell>
				<tradeTagsBuy>
					<li>AnimalExotic</li>
				</tradeTagsBuy>
				<kindCountRange>2~6</kindCountRange>
				<countRange>4~8</countRange>
			</li>
			<li Class="StockGenerator_Category">
				<categoryDef>Drugs</categoryDef>
			</li>
			<li Class="StockGenerator_Category">
				<categoryDef>Textiles</categoryDef>
			</li>
			<li Class="StockGenerator_BuyTradeTag"><tag>Art</tag></li>
			
			<!-- Buying -->
			<li Class="StockGenerator_BuyExpensiveSimple"/>
		</stockGenerators>
	</TraderKindDef>

