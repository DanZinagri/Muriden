<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ScenarioDef ParentName="ScenarioBase">
        <defName>Muriden_Scenario_Refugees</defName>
        <label>Muriden Refugees</label>
        <description>One night, your clan was abruptly destroyed by an unknown force. You and your two companions are the only ones who made it out alive.\nYour group managed to pack a few supplies and wandered the rimworld for a few quadrums, trying to lose your assailants and settle on a peaceful land before your supplies run out completely.</description>
        <scenario>
            <summary>Four Muriden Refugees attempt to create a new settlement after losing everything.</summary>
            <playerFaction>
                <factionDef>MuridenMedievalPlayerColony</factionDef>
            </playerFaction>
            <parts>
                <!-- Config pages -->
                <li Class="ScenPart_ConfigPage_ConfigureStartingPawns_Xenotypes">
                    <def>ConfigPage_ConfigureStartingPawns</def>
                    <pawnChoiceCount>5</pawnChoiceCount>
                    <xenotypeCounts>
                        <li>
                            <xenotype>Muriden</xenotype>
                            <count>3</count>
                            <description>Muriden</description>
                            <requiredAtStart>true</requiredAtStart>
                            <!--<allowedDevelopmentalStages>Adult, Child</allowedDevelopmentalStages>-->
                        </li>
                        <li>
                            <xenotype>Sciurus</xenotype>
                            <count>2</count>
                            <description>Sciurus</description>
                            <requiredAtStart>true</requiredAtStart>
                        </li>
                    </xenotypeCounts>
                </li>
                <li Class="ScenPart_PlayerPawnsArriveMethod">
                    <def>PlayerPawnsArriveMethod</def>
                    <method>Standing</method>
                    <visible>false</visible>
                </li>

                <!-- Starting research -->
                <li Class="ScenPart_StartingResearch">
                    <def>StartingResearch</def>
                    <project>Stonecutting</project>
                </li>

                <!--Player starting things-->
                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Silver</thingDef>
                    <count>500</count>
                </li>

                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Pemmican</thingDef>
                    <count>500</count>
                </li>

                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>MedicineHerbal</thingDef>
                    <count>20</count>
                </li>

                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Muriden_DragonSlayerArmor</thingDef>
                    <stuff>Steel</stuff>
                </li>

                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Muriden_HeavyShield</thingDef>
                    <stuff>Steel</stuff>
                </li>

                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Muriden_TyrantCrown</thingDef>
                    <stuff>Steel</stuff>
                </li>

                <li Class="ScenPart_StartingThing_Defined">
                    <def>StartingThing_Defined</def>
                    <thingDef>Muradin_NobleLongsword</thingDef>
                    <stuff>Plasteel</stuff>
                </li>

                <!-- Scatter some things near player start -->
                <li Class="ScenPart_ScatterThingsNearPlayerStart">
                    <def>ScatterThingsNearPlayerStart</def>
                    <thingDef>Steel</thingDef>
                    <count>400</count>
                </li>
                <li Class="ScenPart_ScatterThingsNearPlayerStart">
                    <def>ScatterThingsNearPlayerStart</def>
                    <thingDef>WoodLog</thingDef>
                    <count>300</count>
                </li>
                <li MayRequire="OskarPotocki.VanillaFactionsExpanded.Core" Class="VEF.Factions.ScenPart_ForcedFactionGoodwill">
                    <factionDef>Muridenia</factionDef>
                    <affectHiddenFactions>False</affectHiddenFactions>
                    <affectStartingGoodwill>True</affectStartingGoodwill>
                    <startingGoodwillRange>25~75</startingGoodwillRange>
                    <affectNaturalGoodwill>True</affectNaturalGoodwill>
                    <naturalGoodwillRange>25~75</naturalGoodwillRange>
                    <def>VFEC_ForcedFactionGoodwill</def>
                </li>

                <!-- Game start dialog -->
                <li Class="ScenPart_GameStartDialog">
                    <def>GameStartDialog</def>
                    <text>With the help of your colleagues you managed to save a set of Muriden Knight armor, along with a sword that has been passed through the clan for generations. The sword is of a strange material rumored to have been forged from a strange meteorite.</text>
                    <closeSound>GameStartSting</closeSound>
                </li>
            </parts>
        </scenario>
    </ScenarioDef>
</Defs>
