<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Atavism Libraries</li>
    </mods>

    <match Class="PatchOperationSequence">
      <operations>
        <li Class="PatchOperationAdd">
          <xpath>/Defs</xpath>
          <value>
              <AtavismLibraries.GeneticAtavismDef>
                <defName>Muriden_To_FeralMuriden</defName>
                <requiredGene>Muriden_Resolve</requiredGene>
                <sourceXenotype>Muriden</sourceXenotype>
                <targetXenotype>FeralMuriden</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>

              <AtavismLibraries.GeneticAtavismDef>
                <defName>FeralMuriden_To_Muriden</defName>
                <requiredGene>FeralMuriden_Resolve</requiredGene>
                <sourceXenotype>FeralMuriden</sourceXenotype>
                <targetXenotype>Muriden</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>

              <AtavismLibraries.GeneticAtavismDef>
                <defName>Choerites_To_Artigasen</defName>
                <requiredGene>Choerites_Calm</requiredGene>
                <sourceXenotype>Choerites</sourceXenotype>
                <targetXenotype>Artigasen</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>

              <AtavismLibraries.GeneticAtavismDef>
                <defName>Artigasen_To_Choerites</defName>
                <requiredGene>Artigasen_Might</requiredGene>
                <sourceXenotype>Artigasen</sourceXenotype>
                <targetXenotype>Choerites</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>

              <AtavismLibraries.GeneticAtavismDef>
                <defName>Sciurus_to_Kopidan</defName>
                <requiredGene>Sciurus_Alacrity</requiredGene>
                <sourceXenotype>Sciurus</sourceXenotype>
                <targetXenotype>Kopidan</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>

              <AtavismLibraries.GeneticAtavismDef>
                <defName>Kopidan_to_Sciurus</defName>
                <requiredGene>Kopidan_Tenacity</requiredGene>
                <sourceXenotype>Kopidan</sourceXenotype>
                <targetXenotype>Sciurus</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>

              <AtavismLibraries.GeneticAtavismDef>
                <defName>Castoran_to_Castoroid</defName>
                <requiredGene>Castoran_Ingenuity</requiredGene>
                <sourceXenotype>Castoran</sourceXenotype>
                <targetXenotype>Castoroid</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>

              <AtavismLibraries.GeneticAtavismDef>
                <defName>Castoroid_to_Castoran</defName>
                <requiredGene>Castoroid_Ingenuity</requiredGene>
                <sourceXenotype>Castoroid</sourceXenotype>
                <targetXenotype>Castoran</targetXenotype>
                <chance>0.05</chance>
                <InheritanceMode>none</InheritanceMode>
              </AtavismLibraries.GeneticAtavismDef>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>
